# Copy to .env for local development. On Railway these are set as service variables.

# PostgreSQL connection string.
# Railway provides this automatically as DATABASE_URL when you add a Postgres plugin.
DATABASE_URL=postgres://user:password@localhost:5432/mmo

# Shared secret that Roblox servers must send in the X-Api-Key header.
# Generate a long random value (e.g. `openssl rand -hex 32`) and set the SAME
# value in your Roblox server's config (a ModuleScript, never a LocalScript).
API_KEY=change-me-to-a-long-random-secret

# Port the API listens on. Railway sets PORT automatically; default for local.
PORT=3000
